#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

echo "Running pre-commit checks..."

# Python lint + format check
echo "  Ruff check..."
cd "${ROOT_DIR}/server"
if command -v uv >/dev/null 2>&1; then
    uv run ruff check src
    uv run ruff format --check src
else
    .venv/bin/ruff check src
    .venv/bin/ruff format --check src
fi

# Go lint
cd "${ROOT_DIR}/cli/src"
if command -v golangci-lint >/dev/null 2>&1; then
    echo "  golangci-lint..."
    golangci-lint run ./...
else
    echo "  Go vet (golangci-lint not found)..."
    go vet ./...
fi

# Auto-regenerate schema docs if models changed
if git diff --cached --name-only | grep -q "server/src/nebula_models/"; then
    echo "  Models changed, regenerating schema docs..."
    cd "${ROOT_DIR}"
    make docs-schema
    git add docs/SCHEMA.md
fi

# Auto-regenerate changelog
if command -v git-cliff >/dev/null 2>&1; then
    echo "  Regenerating changelog..."
    cd "${ROOT_DIR}"
    git-cliff -o docs/CHANGELOG.md
    git add docs/CHANGELOG.md
fi

echo "All pre-commit checks passed"
